{
    "functions": {
        "api/index.py": {
            "maxDuration": 60
        }
    },
    "rewrites": [
        {
            "source": "/",
            "destination": "/web/index.html",
            "has": [{"type": "host", "value": "arang.net"}]
        },
        {
            "source": "/(.*)",
            "destination": "/web/$1",
            "has": [{"type": "host", "value": "arang.net"}]
        },
        {
            "source": "/",
            "destination": "/web/index.html",
            "has": [{"type": "host", "value": "www.arang.net"}]
        },
        {
            "source": "/(.*)",
            "destination": "/web/$1",
            "has": [{"type": "host", "value": "www.arang.net"}]
        },
        {
            "source": "/((?!static/|web/).*)",
            "destination": "/api/index"
        }
    ],
    "crons": [
        {
            "path": "/api/cron/collect",
            "schedule": "0 22 * * *"
        }
    ]
}
